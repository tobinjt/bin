#!/bin/bash

set -e -f -u -o pipefail

check_existing_hooks() {
  local hook_file="$1"
  local legacy_hook_file="${hook_file}.legacy"
  if [[ -L "${legacy_hook_file}" || -e "${legacy_hook_file}" ]]; then
    printf "%s/%s exists\n" "${PWD}" "${legacy_hook_file}" >&2
  fi
  if [[ -e "${hook_file}" ]] && \
      ! grep -q -F 'File generated by pre-commit' "${hook_file}"; then
    printf "%s/%s exists but is not configured by pre-commit\n" \
      "${PWD}" "${hook_file}" >&2
    return 1
  fi
  return 0
}

find_hooks() {
  local hooks_dir="$1"
  find "${hooks_dir}" -maxdepth 1 -type f \
    ! -name "*.sample" ! -name "*.legacy" -print0
}

main() {
  if ! type pre-commit >& /dev/null; then
    return 0
  fi
  local config_file=".pre-commit-config.yaml"
  if [[ ! -f "${config_file}" ]]; then
    return 0
  fi
  if ! git transport-is-ssh; then
    # We don't need pre-commit if we're not committing.
    return 0
  fi

  local hooks_dir=".git/hooks"
  if [[ -d "${hooks_dir}" ]]; then
    # Use find to bypass noglob (set -f) and handle filenames correctly.
    # We check every file that isn't a sample or a legacy file.
    while IFS= read -r -d '' hook_path; do
      if ! check_existing_hooks "${hook_path}"; then
        return 1
      fi
    done < <(find_hooks "${hooks_dir}")
  fi

  local hook
  for hook in "commit-msg" "pre-commit" "pre-push"; do
    local hook_file="${hooks_dir}/${hook}"
    if [[ "${config_file}" -nt "${hook_file}" ]]; then
      printf "Installing pre-commit in %s/%s\n" "${PWD}" "${hook_file}"
      pre-commit install --install-hooks --hook-type "${hook}"
    fi
  done
  return 0
}

main "$@"

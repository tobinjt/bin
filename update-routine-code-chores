#!/bin/bash

set -e -f -u -o pipefail

if [[ -z "${CAFFEINATED:-}" ]] && type caffeinate >& /dev/null; then
  CAFFEINATED="do not sleep"
  export CAFFEINATED
  exec caffeinate -i "$0"
fi

dirs_to_update() {
  set +f
  echo "${HOME}/src/"*
  echo "${HOME}/bin"
  set -f
}

update_workflows() {
  retry "update Github workflows: ${PWD}" -- ./.github/dependabot.yml
  if ! git check-local-copy-is-clean; then
    git commit -a -m "chore: update Github workflows"
  fi
}

update-dotfiles-and-bin
for dir in $(dirs_to_update); do
  if [[ ! -d "${dir}" ]]; then
    continue
  fi
  (cd "${dir}" && retry "update-pre-commit-hooks: ${dir}" \
    -- update-pre-commit-hooks)
  (cd "${dir}" && retry "update-dependencies: ${dir}" \
    -- update-dependencies)
  if [[ -f "${dir}/.github/dependabot.yml" ]]; then
    (cd "${dir}" && update_workflows)
  fi
  git push
  printf "\n\n\n"
done

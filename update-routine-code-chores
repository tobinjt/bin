#!/bin/bash

set -e -f -u -o pipefail

if [[ -z "${CAFFEINATED:-}" ]] && type caffeinate >& /dev/null; then
  CAFFEINATED="do not sleep"
  export CAFFEINATED
  exec caffeinate -i "$0"
fi

dirs_to_update() {
  set +f
  echo "${HOME}/src/"*
  echo "${HOME}/bin"
  set -f
}

update_workflows() {
  retry "update Github workflows: ${PWD}" -- ./.github/dependabot.yml
  if ! git check-local-copy-is-clean --ignore-unpushed-commits; then
    git add --all .
    git commit --quiet --message "chore: update Github workflows"
  fi
}

update_pre_commit() {
  retry "update pre-commit config: ${PWD}" -- ./.pre-commit-config.yaml
  if ! git check-local-copy-is-clean --ignore-unpushed-commits; then
    pre-commit run --all-files
    git add --all .
    git commit --quiet --message "chore: update pre-commit configuration"
    install-pre-commit-hooks
  fi
}

update_everything() {
  # Skip repos that I cannot push to.
  if git transport-is-https; then
    return
  fi
  # Skip forked repos, I should not be updating pre-commit hooks there.
  if git remote show | grep -q upstream; then
    return
  fi

  if [[ -x ".github/dependabot.yml" ]]; then
    update_workflows
  fi
  if [[ -x ".pre-commit-config.yaml" ]]; then
    update_pre_commit
  fi
  if git config remote.origin.url >& /dev/null; then
    git push
  fi
}

for dir in $(dirs_to_update); do
  if [[ ! -d "${dir}" ]]; then
    continue
  fi
  (cd "${dir}" && update_everything)
  printf "\n\n\n"
done
